'use client'
import { useState } from 'react'
import { SPECIES, Species, SKAGIT_SECTIONS, RiverSection, GEAR_ICON_INFO, GearIconCode } from '@/lib/fishing-data'
import FishDetailSheet from './FishDetailSheet'

// Verified fishing tips — only add what is genuinely accurate for WA
