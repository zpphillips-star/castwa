}

// ─── GEAR ICON BADGE ─────────────────────────────────────────────────────────

function GearBadge({ code }: { code: GearIconCode }) {
  const info = GEAR_ICON_INFO[code]
  // Emergency, closures and tribal get red; everything else gets a neutral slate
  const isAlert = ['EMERGENCY_RULE','TRIBAL_CLOSURE_RISK','CLOSED_WATERS_SUMMER','NO_MOTORS'].includes(code)
  const bg    = isAlert ? 'rgba(239,68,68,0.12)'  : 'rgba(255,255,255,0.06)'
  const border= isAlert ? 'rgba(239,68,68,0.35)'  : 'rgba(255,255,255,0.12)'
  const color = isAlert ? '#ef4444'               : 'var(--text-muted)'
  return (
    <div className="flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-semibold"
      style={{ background: bg, border: `1px solid ${border}`, color }}>
      <span>{info.icon}</span>
      <span>{info.label}</span>
    </div>
  )
}

// ─── LEGEND POPUP ─────────────────────────────────────────────────────────────

const LEGEND_CODES: GearIconCode[] = [
  'SGR','SINGLE_BARBLESS','ANTI_SNAGGING','NIGHT_CLOSURE',
  'TWO_POLE_OK','NO_MOTORS','CATCH_AND_RELEASE','TRIBAL_CLOSURE_RISK',
]

function LegendPopup({ onClose }: { onClose: () => void }) {
  return (
    <div className="fixed inset-0 z-[80] flex items-end justify-end p-4"
      onClick={onClose}
      style={{ background: 'rgba(0,0,0,0.6)' }}>
      <div className="rounded-xl p-4 w-full max-w-xs"
        onClick={e => e.stopPropagation()}
        style={{ background: 'var(--surface)', border: '1px solid var(--border)', maxHeight: '70vh', overflowY: 'auto' }}>
        <div className="flex items-center justify-between mb-3">
          <p className="text-sm font-bold text-white">Gear Icon Legend</p>
          <button onClick={onClose}
            className="w-6 h-6 rounded-full flex items-center justify-center text-xs"
            style={{ background: 'rgba(255,255,255,0.1)', color: 'var(--text-muted)' }}>✕</button>
        </div>
        <div className="space-y-2.5">
          {LEGEND_CODES.map(code => {
            const info = GEAR_ICON_INFO[code]
            return (
              <div key={code} className="flex items-start gap-2">
                <span className="text-base flex-shrink-0 mt-0.5">{info.icon}</span>
                <div>
                  <p className="text-xs font-semibold text-white">{info.label}</p>
                  <p className="text-[11px] leading-snug" style={{ color: 'var(--text-faint)' }}>{info.detail}</p>
                </div>
              </div>
            )
          })}
        </div>
      </div>
    </div>
  )
}

// ─── SKAGIT SECTION CARD ──────────────────────────────────────────────────────

function SkagitSectionCard({ section }: { section: RiverSection }) {
  const [open, setOpen] = useState(false)
  const hasEmergency = !!section.emergencyRule
  const hasClosures = section.emergencyRule?.overrides.some(o => o.status === 'CLOSED')

  return (
    <div className="rounded-xl overflow-hidden"
      style={{ border: `1px solid ${hasEmergency ? 'rgba(239,68,68,0.3)' : 'var(--border)'}`, background: 'var(--surface-raised)' }}>

      {/* Header — always visible */}
      <button onClick={() => setOpen(v => !v)}
        className="w-full px-3 py-2.5 flex items-center justify-between text-left">
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2 mb-0.5 flex-wrap">
            <p className="text-sm font-semibold text-white leading-tight">{section.name}</p>
            {hasEmergency && (
              <span className="text-[9px] font-bold px-1.5 py-0.5 rounded flex-shrink-0"
                style={{ background: 'rgba(239,68,68,0.15)', color: '#ef4444' }}>
                {hasClosures ? '⚠️ CLOSURES' : '🚨 EMERGENCY'}
              </span>
            )}
          </div>
          <p className="text-[11px]" style={{ color: 'var(--text-faint)' }}>CRC #{section.crc}</p>
        </div>
        <span className="ml-3 text-xs flex-shrink-0" style={{ color: 'var(--text-faint)' }}>{open ? '▲' : '▼'}</span>
      </button>

      {open && (
        <div className="pb-3 space-y-0" style={{ borderTop: '1px solid var(--border)' }}>

          {/* Gear icons — compact row */}
          <div className="px-3 pt-3 pb-2">
            <p className="text-[10px] font-bold mb-2" style={{ color: 'var(--text-faint)' }}>GEAR RULES</p>
            <div className="flex flex-wrap gap-1.5">
              {section.gearIcons.map(code => <GearBadge key={code} code={code} />)}
            </div>
          </div>

          {/* Gear periods — plain list, no colored dates */}
          {section.gearPeriods.length > 0 && (
            <div className="px-3 pb-2">
              <div className="rounded-lg overflow-hidden" style={{ border: '1px solid var(--border)' }}>
                {section.gearPeriods.map((p, i) => (
                  <div key={i} className="px-3 py-2 flex gap-3 items-baseline"
                    style={{ borderBottom: i < section.gearPeriods.length - 1 ? '1px solid var(--border)' : 'none', background: 'var(--bg)' }}>
                    <span className="text-[11px] font-semibold flex-shrink-0 w-28 text-white">{p.dates}</span>
                    <span className="text-[11px] leading-snug" style={{ color: 'var(--text-muted)' }}>{p.rules}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Season table — clean rows */}
          <div className="px-3 pb-2">
            <p className="text-[10px] font-bold mb-2" style={{ color: 'var(--text-faint)' }}>WHAT'S OPEN</p>
            <div className="rounded-lg overflow-hidden" style={{ border: '1px solid var(--border)' }}>
              {section.seasons.map((s, i) => (
                <div key={i} className="px-3 py-2.5"
                  style={{ borderBottom: i < section.seasons.length - 1 ? '1px solid var(--border)' : 'none', background: 'var(--bg)' }}>
                  <div className="flex items-start justify-between gap-2">
                    <div className="flex-1 min-w-0">
                      <p className="text-xs font-semibold text-white leading-tight">{s.species}</p>
                      {!s.closed && s.open && (
                        <p className="text-[11px] mt-0.5" style={{ color: 'var(--text-muted)' }}>{s.open}</p>
                      )}
                      {s.notes && (
                        <p className="text-[10px] mt-0.5 leading-snug" style={{ color: 'var(--text-faint)' }}>{s.notes}</p>
                      )}
                    </div>
                    <div className="flex-shrink-0 text-right">
                      {s.closed ? (
                        <span className="text-[10px] font-bold" style={{ color: '#ef4444' }}>CLOSED</span>
                      ) : (
                        <div>
                          <span className="text-[10px] font-bold" style={{ color: '#6ab04c' }}>OPEN</span>
                          {s.dailyLimit && (
                            <p className="text-[10px] mt-0.5" style={{ color: 'var(--text-faint)' }}>Limit {s.dailyLimit}</p>
                          )}
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Emergency rule — compact */}
          {section.emergencyRule && (
            <div className="px-3 pb-1">
              <div className="rounded-lg p-3" style={{ background: 'rgba(239,68,68,0.06)', border: '1px solid rgba(239,68,68,0.25)' }}>
                <div className="flex items-center justify-between mb-2">
                  <p className="text-xs font-bold" style={{ color: '#ef4444' }}>🚨 Emergency Rule Active</p>
                  <p className="text-[10px]" style={{ color: 'var(--text-faint)' }}>{section.emergencyRule.effective}</p>
                </div>
                <div className="space-y-1.5">
                  {section.emergencyRule.overrides.map((o, i) => (
                    <div key={i} className="flex gap-2 items-baseline">
                      <span className="text-[10px] font-semibold flex-shrink-0 w-28"
                        style={{ color: o.status === 'CLOSED' ? '#ef4444' : 'var(--text-muted)' }}>
                        {o.status === 'CLOSED' ? '⛔ ' : ''}{o.dates}
                      </span>
                      <span className="text-[11px] leading-snug" style={{ color: 'var(--text-faint)' }}>{o.notes}</span>
                    </div>
                  ))}
                </div>
                <a href={section.emergencyRule.url} target="_blank" rel="noopener noreferrer"
                  className="block text-xs font-semibold mt-2 active:opacity-70"
                  style={{ color: '#ef4444' }}>
                  Full rule at WDFW.wa.gov →
                </a>
              </div>
            </div>
          )}

          {/* Boundary + map links — collapsed into a subtle row */}
          <div className="px-3 pt-1">
            <p className="text-[10px] mb-1 leading-relaxed" style={{ color: 'var(--text-faint)' }}>
              {section.boundary} <span className="italic">({section.coordsNote})</span>
            </p>
            <div className="flex gap-2">
              <a href={section.mapsLinkDownstream} target="_blank" rel="noopener noreferrer"
                className="text-[11px] font-semibold px-2.5 py-1.5 rounded-lg active:opacity-70"
                style={{ background: 'rgba(255,255,255,0.06)', border: '1px solid var(--border)', color: 'var(--text-muted)' }}>
                📍 Downstream
              </a>
              <a href={section.mapsLinkUpstream} target="_blank" rel="noopener noreferrer"
                className="text-[11px] font-semibold px-2.5 py-1.5 rounded-lg active:opacity-70"
                style={{ background: 'rgba(255,255,255,0.06)', border: '1px solid var(--border)', color: 'var(--text-muted)' }}>
                📍 Upstream
              </a>
            </div>
          </div>

        </div>
      )}
    </div>
  )
}


type RiverData = {
  id: string
  name: string
  region: string
  usgsId: string
  targetSpecies: string[]
  idealCfs: { min: number; max: number }
  description?: string
  access?: string[]
  fishingTips?: string[]
}

type FlowData = {
  cfs: number | null
  status: 'ideal' | 'low' | 'high' | 'loading' | 'error'
  trend: 'rising' | 'falling' | 'stable' | null
  fetchedAt: string
}

interface Props {
  river: RiverData
  flow: FlowData
  onClose: () => void
}

